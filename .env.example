# PostgreSQL — for Coolify use the internal URL from the DB service
# For local docker-compose: postgresql://postgres:postgres@localhost:5432/schedulehairdresser
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Full public URL of the app (no trailing slash)
NEXTAUTH_URL="https://your-domain.com"
PUBLIC_URL="https://your-domain.com"

# WhatsApp: "mock" logs messages to DB | "real" sends via Twilio
WHATSAPP_MODE="mock"

# Twilio credentials (only needed for WHATSAPP_MODE=real)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
